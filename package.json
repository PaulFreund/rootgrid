{
  "name": "rootgrid",
  "version": "0.0.0",
  "type": "module",
  "description": "Rootgrid - local-first web UI for driving Codex via codex app-server",
  "license": "UNLICENSED",
  "bin": {
    "rootgrid": "./src/cli.js"
  },
  "files": [
    "src/",
    "web/dist/",
    "README.md",
    "docs/",
    "DesignDecisions.md",
    "AGENTS.md",
    "Todo.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:host": "node ./src/cli.js",
    "dev:web": "cd web && vite --config vite.config.js",
    "dev": "node ./scripts/dev.js",
    "test": "node --test",
    "build:web": "cd web && vite build --config vite.config.js",
    "build": "npm run build:web",
    "prepack": "npm run build:web",
    "setup": "node ./src/cli.js setup"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.55.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-vue": "^6.0.4",
    "autoprefixer": "^10.4.27",
    "dompurify": "^3.3.1",
    "lucide-vue-next": "^0.576.0",
    "marked": "^17.0.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.29"
  }
}
